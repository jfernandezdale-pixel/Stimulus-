<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Apply to Stimulus - Claim Your $2,000</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: #ffffff;
            color: #1a1a2e;
            line-height: 1.4;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* Top Bar */
        .top-bar {
            background: #dc2626;
            color: #fff;
            text-align: center;
            padding: 10px 16px;
            font-size: 14px;
            font-weight: 800;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        /* Hero */
        .hero {
            background: #1a1a2e;
            color: #fff;
            text-align: center;
            padding: 24px 20px;
        }

        .hero h1 {
            font-size: 32px;
            font-weight: 900;
            margin-bottom: 6px;
            line-height: 1.1;
            text-transform: uppercase;
        }

        .hero .amount {
            font-size: 56px;
            font-weight: 900;
            color: #fbbf24;
            margin: 8px 0;
            text-shadow: 0 2px 10px rgba(251, 191, 36, 0.3);
            line-height: 1;
        }

        .hero .amount-label {
            font-size: 16px;
            color: #fbbf24;
            font-weight: 700;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .hero .subtitle {
            font-size: 16px;
            color: #94a3b8;
            margin-bottom: 14px;
            font-weight: 500;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #dc2626;
            color: #fff;
            padding: 8px 18px;
            border-radius: 25px;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 12px;
            box-shadow: 0 4px 15px rgba(220, 38, 38, 0.4);
        }

        .hero-badge::before {
            content: "●";
            color: #fff;
            animation: pulse 1.5s infinite;
            font-size: 14px;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* CTA Button */
        .cta-btn {
            display: block;
            width: calc(100% - 40px);
            max-width: 380px;
            margin: 0 auto 10px;
            background: #16a34a;
            color: #fff;
            text-align: center;
            padding: 16px 24px;
            border-radius: 10px;
            font-size: 18px;
            font-weight: 800;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            box-shadow: 0 6px 20px rgba(22, 163, 74, 0.4);
            transition: transform 0.15s, box-shadow 0.15s;
            border: 2px solid #22c55e;
        }

        .cta-btn:active {
            transform: scale(0.97);
        }

        .cta-sub {
            text-align: center;
            font-size: 14px;
            color: #94a3b8;
            margin-bottom: 4px;
            font-weight: 600;
        }

        /* Trust Bar */
        .trust-bar {
            display: flex;
            justify-content: center;
            gap: 24px;
            padding: 12px 20px;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 14px;
            color: #475569;
            font-weight: 700;
        }

        .trust-item::before {
            content: "✓";
            color: #16a34a;
            font-weight: 900;
            font-size: 16px;
        }

        /* Features */
        .features {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding: 16px 16px;
            background: #fff;
        }

        .feature {
            text-align: center;
            padding: 12px 6px;
            background: #f8fafc;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
        }

        .feature-icon {
            width: 44px;
            height: 44px;
            margin: 0 auto 8px;
            background: #1a1a2e;
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .feature h3 {
            font-size: 14px;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 4px;
        }

        .feature p {
            font-size: 12px;
            color: #64748b;
            line-height: 1.4;
        }

        /* Steps */
        .steps {
            display: flex;
            justify-content: space-around;
            padding: 14px 16px;
            background: #f1f5f9;
            border-top: 2px solid #e2e8f0;
            border-bottom: 2px solid #e2e8f0;
        }

        .step {
            text-align: center;
            flex: 1;
            position: relative;
        }

        .step:not(:last-child)::after {
            content: "→";
            position: absolute;
            right: -8px;
            top: 14px;
            color: #94a3b8;
            font-size: 14px;
            font-weight: 700;
        }

        .step-num {
            width: 34px;
            height: 34px;
            background: #1a1a2e;
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 900;
            margin: 0 auto 6px;
            box-shadow: 0 2px 8px rgba(26, 26, 46, 0.3);
        }

        .step h4 {
            font-size: 14px;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 2px;
        }

        .step p {
            font-size: 11px;
            color: #64748b;
            font-weight: 500;
        }

        /* Urgency */
        .urgency {
            background: #dc2626;
            color: #fff;
            text-align: center;
            padding: 14px 20px;
        }

        .urgency h2 {
            font-size: 18px;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 4px;
            letter-spacing: 0.5px;
        }

        .urgency p {
            font-size: 13px;
            opacity: 0.95;
            font-weight: 500;
        }

        /* Bottom CTA */
        .bottom-cta {
            padding: 16px 20px;
            text-align: center;
            background: #fff;
        }

        .bottom-cta .cta-btn {
            margin-bottom: 10px;
            font-size: 17px;
            padding: 16px;
            background: #dc2626;
            border-color: #ef4444;
            box-shadow: 0 6px 20px rgba(220, 38, 38, 0.4);
        }

        .guarantee {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 8px;
            flex-wrap: wrap;
        }

        .guarantee span {
            font-size: 13px;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 4px;
            font-weight: 600;
        }

        .guarantee span::before {
            content: "●";
            color: #16a34a;
            font-size: 10px;
        }

        /* Desktop */
        @media (min-width: 768px) {
            .hero h1 { font-size: 42px; }
            .hero .amount { font-size: 72px; }
            .hero { padding: 40px; }
            .features { max-width: 700px; margin: 0 auto; }
            .steps { max-width: 700px; margin: 0 auto; }
        }
    </style>
</head>
<body>

    <div class="top-bar">LIMITED TIME - $2,000 Payment Available</div>

    <section class="hero">
        <div class="hero-badge">Live Now</div>
        <h1>Apply to Stimulus</h1>
        <div class="amount">$2,000</div>
        <div class="amount-label">Direct Payment Available</div>
        <p class="subtitle">Approved Americans are claiming now. Don't miss out.</p>
        <p style="font-size: 15px; color: #cbd5e1; margin-bottom: 16px;">
            Quick eligibility check. No credit check. Direct payment to your account.
        </p>
        <a href="https://trksy.org/aff_c?offer_id=3200&aff_id=14776" class="cta-btn">CLAIM NOW</a>
        <p class="cta-sub">✓ Instant eligibility confirmation</p>
    </section>

    <div class="trust-bar">
        <span class="trust-item">No Risk</span>
        <span class="trust-item">2 min</span>
        <span class="trust-item">Instant</span>
    </div>

    <section class="features">
        <div class="feature">
            <div class="feature-icon">📄</div>
            <h3>Zero Paperwork</h3>
            <p>Answer 3 quick questions. No documents needed.</p>
        </div>
        <div class="feature">
            <div class="feature-icon">⚡</div>
            <h3>Ultra-Fast</h3>
            <p>2 minutes max. Get approved instantly.</p>
        </div>
        <div class="feature">
            <div class="feature-icon">🔒</div>
            <h3>Bank Security</h3>
            <p>Military-grade encryption. 100% protected.</p>
        </div>
    </section>

    <section class="steps">
        <div class="step">
            <div class="step-num">1</div>
            <h4>Check</h4>
            <p>2-min eligibility check</p>
        </div>
        <div class="step">
            <div class="step-num">2</div>
            <h4>Apply</h4>
            <p>Simple application form</p>
        </div>
        <div class="step">
            <div class="step-num">3</div>
            <h4>Get Paid</h4>
            <p>Receive your $2,000</p>
        </div>
    </section>

    <div class="urgency">
        <h2>Final Call - Slots Filling Up</h2>
        <p>Act now before funds run out. Thousands approved every hour.</p>
    </div>

    <div class="bottom-cta">
        <a href="https://trksy.org/aff_c?offer_id=3200&aff_id=14776" class="cta-btn">CLAIM NOW</a>
        <div class="guarantee">
            <span>Money Back Guarantee</span>
            <span>Secure SSL Encryption</span>
            <span>24/7 Support</span>
        </div>
    </div>

</body>
</html>
